# Copy to .env for local sync runs: `npm run sync`
# Both vars MUST also be added as repo Action secrets for the scheduled sync to work.

# The Drive folder ID (the part after /folders/ in the URL).
GDRIVE_FOLDER_ID=1WILT2WleC0ztjwdgNo1-cvFrrBcwcK3e

# The full service-account JSON, on a single line (escape inner newlines as \n).
# Easiest: `GDRIVE_SA_KEY={"type":"service_account",...}`
GDRIVE_SA_KEY=
