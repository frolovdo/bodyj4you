{%- comment -%}
  creators-partnership.liquid
  ---------------------------
  Storefront page where a creator picks free products from your real catalog,
  builds a cart, and submits a form. The form is sent to the backend through an
  App Proxy (`proxy_url`) which creates a $0, already-paid order.

  Products shown = the collection chosen in the section settings. Add/remove
  products by editing that collection in Shopify admin - no code changes needed.
{%- endcomment -%}

{{ 'creators-partnership.css' | asset_url | stylesheet_tag }}

{%- assign gift_collection = collections[section.settings.collection] -%}

<section
  class="creators"
  data-creators
  data-proxy-url="{{ section.settings.proxy_url }}"
  data-max-items="{{ section.settings.max_items }}"
  data-agreement-url="{{ section.settings.agreement_url }}"
>
  <header class="creators__header">
    <h1>{{ section.settings.heading }}</h1>
    <p>{{ section.settings.subheading }}</p>
    <p class="creators__hint">
      Pick up to {{ section.settings.max_items }} items — everything is free.
    </p>
  </header>

  {%- if gift_collection == blank or gift_collection.products_count == 0 -%}
    <p class="creators__empty">
      No products are available yet. (Set the “Gift collection” in the theme editor.)
    </p>
  {%- else -%}
    <div class="creators__grid">
      {%- for product in gift_collection.products -%}
        <article class="creators-card" data-product-id="{{ product.id }}">
          {%- if product.featured_image -%}
            <img
              class="creators-card__image"
              src="{{ product.featured_image | image_url: width: 400 }}"
              alt="{{ product.title | escape }}"
              loading="lazy"
              width="400"
            >
          {%- endif -%}

          <h3 class="creators-card__title">{{ product.title }}</h3>
          <p class="creators-card__price">FREE</p>

          {%- comment -%} Variant picker (e.g. size). Single-variant products hide it. {%- endcomment -%}
          {%- if product.variants.size > 1 -%}
            <label class="creators-card__variant">
              <span>Choose option</span>
              <select data-variant-select>
                {%- for variant in product.variants -%}
                  <option
                    value="{{ variant.id }}"
                    {% unless variant.available %}disabled{% endunless %}
                  >
                    {{ variant.title }}{% unless variant.available %} — Sold out{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            </label>
          {%- else -%}
            <input type="hidden" data-variant-select value="{{ product.variants.first.id }}">
          {%- endif -%}

          <button
            type="button"
            class="creators-card__toggle"
            data-toggle-item
            data-product-title="{{ product.title | escape }}"
            {% unless product.available %}disabled{% endunless %}
          >
            {% if product.available %}Add{% else %}Sold out{% endif %}
          </button>
        </article>
      {%- endfor -%}
    </div>

    {%- comment -%} Sticky summary + the button that opens the form. {%- endcomment -%}
    <div class="creators__bar" data-summary-bar hidden>
      <span data-summary-count>0</span> selected · Total: <strong>$0.00</strong>
      <button type="button" class="creators__cta" data-open-form disabled>
        Create an order
      </button>
    </div>
  {%- endif -%}

  {%- comment -%} ----- The form (hidden until "Create an order") ----- {%- endcomment -%}
  <div class="creators-modal" data-form-modal hidden>
    <div class="creators-modal__panel">
      <button type="button" class="creators-modal__close" data-close-form aria-label="Close">×</button>
      <h2>Your details</h2>

      <ul class="creators-modal__items" data-form-items></ul>

      <form data-creator-form>
        <fieldset>
          <legend>Contact</legend>
          <input name="firstName" placeholder="First name" required>
          <input name="lastName" placeholder="Last name" required>
          <input name="email" type="email" placeholder="Email" required>
          <input name="phone" placeholder="Phone (optional)">
        </fieldset>

        <fieldset>
          <legend>Shipping address</legend>
          <input name="address1" placeholder="Address" required>
          <input name="address2" placeholder="Apt / suite (optional)">
          <input name="city" placeholder="City" required>
          <input name="province" placeholder="State / province">
          <input name="zip" placeholder="ZIP / postal code" required>
          <input name="country" placeholder="Country" required>
        </fieldset>

        <fieldset>
          <legend>Social media</legend>
          <input name="instagram" placeholder="Instagram handle">
          <input name="tiktok" placeholder="TikTok handle">
          <input name="youtube" placeholder="YouTube channel">
          <input name="other" placeholder="Other (optional)">
        </fieldset>

        <label class="creators-modal__agree">
          <input type="checkbox" name="agreementAccepted" checked required>
          <span>
            I agree to the influencer agreement — I’ll receive these items free in
            exchange for a social media post/video.
            <a href="#" data-agreement-link target="_blank" rel="noopener">Read</a>
          </span>
        </label>

        <p class="creators-modal__error" data-form-error hidden></p>

        <button type="submit" class="creators__cta" data-submit-form>
          Create an order
        </button>
      </form>

      <div class="creators-modal__success" data-success hidden>
        <h2>You’re all set! 🎉</h2>
        <p>Your order <strong data-order-name></strong> has been created. We’ll ship it out shortly.</p>
      </div>
    </div>
  </div>
</section>

{{ 'creators-partnership.js' | asset_url | script_tag }}

{% schema %}
{
  "name": "Creators partnership",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Creator Partnership" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Choose the products you'd like and we'll send them your way." },
    { "type": "collection", "id": "collection", "label": "Gift collection", "info": "Products in this collection are offered for free." },
    { "type": "range", "id": "max_items", "label": "Max items per creator", "min": 1, "max": 10, "step": 1, "default": 5 },
    { "type": "header", "content": "Wiring" },
    { "type": "text", "id": "proxy_url", "label": "Order endpoint (App Proxy)", "default": "/apps/creators/order" },
    { "type": "url", "id": "agreement_url", "label": "Influencer agreement link" }
  ],
  "presets": [{ "name": "Creators partnership" }]
}
{% endschema %}
