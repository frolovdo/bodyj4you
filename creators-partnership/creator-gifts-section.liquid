{%- comment -%}
  ============================================================================
  CREATOR GIFTS — paste-in block (no app, no backend, no coupon)
  ============================================================================
  HOW TO USE
  1. Online Store -> Themes -> Edit theme (Customize).
  2. Top dropdown -> Pages -> Partnership.
  3. Add section -> "Custom Liquid".
  4. Paste this ENTIRE file into the Custom Liquid box and Save.

  ▼▼▼  REPLACE the Google Form link below with YOUR agreement form  ▼▼▼
{%- endcomment -%}

{%- assign gift_collection = collections['creator-gifts'] -%}
{%- assign max_items = 5 -%}
{%- assign agreement_url = 'https://docs.google.com/forms/d/e/1FAIpQLSfRW-3NKnnzOcFAwP35nQCw08C0Fs3_qOi1o6Y4r7ej54ImeA/viewform' -%}

<style>
  .cg { max-width: 1000px; margin: 0 auto; padding: 1.5rem; }
  .cg__head { text-align: center; margin-bottom: 1.5rem; }
  .cg__hint { font-size: .9rem; opacity: .7; }
  .cg__step { font-weight: 600; margin: 1.75rem 0 .5rem; }
  .cg__grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px,1fr)); gap: 1rem; }
  .cg-card { border: 1px solid #ddd; border-radius: 8px; padding: .75rem; display: flex; flex-direction: column; gap: .5rem; }
  .cg-card.is-on { border-color: #111; box-shadow: 0 0 0 2px #111 inset; }
  .cg-card img { width: 100%; height: auto; border-radius: 6px; }
  .cg-card__title { font-size: .95rem; margin: 0; }
  .cg-card__price { font-weight: 700; margin: 0; }
  .cg-card select { padding: .35rem; width: 100%; }
  .cg-card button { margin-top: auto; padding: .5rem; cursor: pointer; border: 1px solid #111; background: #fff; border-radius: 6px; }
  .cg-card.is-on button { background: #111; color: #fff; }
  .cg-card button:disabled { opacity: .4; cursor: not-allowed; }
  .cg__count { font-size: .9rem; opacity: .8; margin-top: .5rem; }

  .cg-form { margin-top: .5rem; display: grid; gap: .6rem; max-width: 520px; }
  .cg-field { display: grid; gap: .25rem; }
  .cg-field input { padding: .55rem; border: 1px solid #ccc; border-radius: 6px; width: 100%; }
  .cg-field input.is-bad { border-color: #c00; }
  .cg-field input.is-good { border-color: #1a7f37; }
  .cg-field__msg { font-size: .75rem; color: #c00; display: none; }
  .cg-field.is-bad .cg-field__msg { display: block; }

  .cg-agree { margin-top: 1.25rem; display: grid; gap: .6rem; max-width: 520px; }
  .cg-agree__open { display: inline-block; padding: .5rem .9rem; border: 1px solid #111; border-radius: 6px; text-decoration: none; color: #111; font-weight: 600; width: max-content; }
  .cg-agree__check { display: flex; gap: .5rem; align-items: flex-start; font-size: .9rem; }

  .cg__footer { margin-top: 1.75rem; display: grid; gap: .5rem; max-width: 520px; }
  .cg__todo { font-size: .8rem; opacity: .7; }
  .cg__cta { padding: .9rem 1.2rem; background: #111; color: #fff; border: none; border-radius: 8px; cursor: pointer; font-size: 1.05rem; font-weight: 700; }
  .cg__cta:disabled { opacity: .4; cursor: not-allowed; }
  .cg-error { color: #c00; font-size: .85rem; }
</style>

<div class="cg" id="cg-app">
  <div class="cg__head">
    <h1>Creator Partnership</h1>
    <p>Pick the products you'd like — everything here is free. Choose up to {{ max_items }}.</p>
  </div>

  {%- if gift_collection == blank or gift_collection.products_count == 0 -%}
    <p>No gift products are available right now. (Add products to the “Creator Gifts” collection.)</p>
  {%- else -%}

    <p class="cg__step">1. Choose your products</p>
    <div class="cg__grid">
      {%- for product in gift_collection.products -%}
        <div class="cg-card" data-card>
          {%- if product.featured_image -%}
            <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title | escape }}" loading="lazy" width="400">
          {%- endif -%}
          <h3 class="cg-card__title">{{ product.title | remove: '[Creator Gift]' | strip }}</h3>
          <p class="cg-card__price">FREE</p>

          {%- if product.variants.size > 1 -%}
            <select data-variant>
              {%- for v in product.variants -%}
                <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>
                  {{ v.title }}{% unless v.available %} — Sold out{% endunless %}
                </option>
              {%- endfor -%}
            </select>
          {%- else -%}
            <input type="hidden" data-variant value="{{ product.variants.first.id }}">
          {%- endif -%}

          <button type="button" data-toggle data-title="{{ product.title | remove: '[Creator Gift]' | strip | escape }}">Add</button>
        </div>
      {%- endfor -%}
    </div>
    <p class="cg__count"><strong data-count>0</strong> selected</p>

    <p class="cg__step">2. Where can we see your content?</p>
    <p class="cg__hint">Add at least one — Instagram, TikTok, or YouTube.</p>
    <div class="cg-form">
      <div class="cg-field">
        <input type="text" data-social="Instagram" placeholder="Instagram handle (e.g. @yourname)">
        <span class="cg-field__msg">That doesn't look like a valid Instagram handle.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="TikTok" placeholder="TikTok handle (e.g. @yourname)">
        <span class="cg-field__msg">That doesn't look like a valid TikTok handle.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="YouTube" placeholder="YouTube channel (@handle or link)">
        <span class="cg-field__msg">That doesn't look like a valid YouTube channel.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="Other" placeholder="Other (optional)">
      </div>
    </div>

    <p class="cg__step">3. Sign the agreement</p>
    <div class="cg-agree">
      <a class="cg-agree__open" href="{{ agreement_url }}" target="_blank" rel="noopener" data-agree-open>
        Read &amp; sign the agreement ↗
      </a>
      <label class="cg-agree__check">
        <input type="checkbox" data-agree>
        <span>I have read, signed, and agree to the influencer agreement — I'll receive these items free in exchange for a social media post/video.</span>
      </label>
    </div>

    <div class="cg__footer">
      <p class="cg-error" data-error hidden></p>
      <p class="cg__todo" data-todo></p>
      <button type="button" class="cg__cta" data-checkout disabled>Create &amp; ship my partner box 🎁</button>
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var app = document.getElementById('cg-app');
  if (!app) return;

  var MAX = {{ max_items }};
  var selected = new Map(); // variantId -> title
  var countEl = app.querySelector('[data-count]');
  var checkoutBtn = app.querySelector('[data-checkout]');
  var agreeEl = app.querySelector('[data-agree]');
  var errorEl = app.querySelector('[data-error]');
  var todoEl = app.querySelector('[data-todo]');

  // ---------- product selection ----------
  app.querySelectorAll('[data-card]').forEach(function (card) {
    var btn = card.querySelector('[data-toggle]');
    var variant = card.querySelector('[data-variant]');
    if (!btn || !variant) return;

    btn.addEventListener('click', function () {
      var id = variant.value;
      if (card.classList.contains('is-on')) {
        selected.delete(card.dataset.selectedId);
        card.classList.remove('is-on');
        card.removeAttribute('data-selected-id');
        btn.textContent = 'Add';
      } else {
        if (selected.size >= MAX) { alert('You can pick at most ' + MAX + ' items.'); return; }
        selected.set(id, btn.getAttribute('data-title'));
        card.dataset.selectedId = id;
        card.classList.add('is-on');
        btn.textContent = 'Remove';
      }
      refresh();
    });

    if (variant.tagName === 'SELECT') {
      variant.addEventListener('change', function () {
        if (card.classList.contains('is-on')) {
          selected.delete(card.dataset.selectedId);
          selected.set(variant.value, btn.getAttribute('data-title'));
          card.dataset.selectedId = variant.value;
          refresh();
        }
      });
    }
  });

  // ---------- social handle validation (lenient) ----------
  function clean(v) { return v.trim().replace(/^@+/, '').replace(/\/+$/, ''); }
  // A real-looking handle: letters/numbers/dots/underscores AND at least one letter.
  function isHandle(v, max) { return new RegExp('^[a-zA-Z0-9._]{2,' + max + '}$').test(v) && /[a-zA-Z]/.test(v); }
  var validators = {
    Instagram: function (v) { return /instagram\.com\/[a-zA-Z0-9._]{2,}/i.test(v) || isHandle(clean(v), 30); },
    TikTok:    function (v) { return /tiktok\.com\/@?[a-zA-Z0-9._]{2,}/i.test(v) || isHandle(clean(v), 24); },
    YouTube:   function (v) { return /(youtube\.com|youtu\.be)\/.+/i.test(v) || (isHandle(clean(v), 30) && clean(v).length >= 3); }
  };

  var socialInputs = Array.prototype.slice.call(app.querySelectorAll('[data-social]'));
  socialInputs.forEach(function (input) {
    input.addEventListener('input', function () {
      var type = input.getAttribute('data-social');
      var field = input.closest('.cg-field');
      var val = input.value.trim();
      var check = validators[type];
      if (!val || !check) {
        input.classList.remove('is-bad', 'is-good');
        if (field) field.classList.remove('is-bad');
      } else if (check(val)) {
        input.classList.add('is-good'); input.classList.remove('is-bad');
        if (field) field.classList.remove('is-bad');
      } else {
        input.classList.add('is-bad'); input.classList.remove('is-good');
        if (field) field.classList.add('is-bad');
      }
      refresh();
    });
  });

  function hasValidSocial() {
    return ['Instagram', 'TikTok', 'YouTube'].some(function (type) {
      var input = app.querySelector('[data-social="' + type + '"]');
      var val = input ? input.value.trim() : '';
      return val && validators[type](val);
    });
  }

  agreeEl.addEventListener('change', refresh);

  // ---------- enable/disable + guidance ----------
  function refresh() {
    var needs = [];
    if (selected.size === 0) needs.push('pick at least 1 product');
    if (!hasValidSocial()) needs.push('add a valid Instagram, TikTok, or YouTube');
    if (!agreeEl.checked) needs.push('check the agreement box');

    countEl.textContent = selected.size;
    checkoutBtn.disabled = needs.length > 0;
    todoEl.textContent = needs.length ? 'To continue: ' + needs.join(', ') + '.' : '';
  }
  refresh();

  // ---------- checkout ----------
  checkoutBtn.addEventListener('click', function () {
    errorEl.hidden = true;
    if (checkoutBtn.disabled) return;

    checkoutBtn.disabled = true;
    checkoutBtn.textContent = 'Preparing…';

    var attributes = { 'Creator gift': 'Yes', 'Influencer agreement': 'Accepted' };
    socialInputs.forEach(function (input) {
      if (input.value.trim()) attributes[input.getAttribute('data-social')] = input.value.trim();
    });

    var items = [];
    selected.forEach(function (title, id) { items.push({ id: Number(id), quantity: 1 }); });

    fetch('/cart/clear.js', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(function () {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        });
      })
      .then(function (r) { if (!r.ok) throw new Error('Could not add items to the cart.'); return r.json(); })
      .then(function () {
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attributes: attributes })
        });
      })
      .then(function () { window.location.href = '/checkout'; })
      .catch(function (err) {
        showError(err.message || 'Something went wrong. Please try again.');
        checkoutBtn.disabled = false;
        checkoutBtn.textContent = 'Create & ship my partner box 🎁';
      });
  });

  function showError(msg) { errorEl.textContent = msg; errorEl.hidden = false; }
})();
</script>
