# Copy to ".env" and fill in. Never commit the real .env.

# Your store domain
SHOPIFY_SHOP=bodyj4you.myshopify.com

# Admin API access token from your custom app (needs scopes:
#   read_customers, write_customers, write_draft_orders, write_orders, read_products)
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxx

# The app's API secret key - used to verify App Proxy request signatures.
SHOPIFY_API_SECRET=shpss_xxxxxxxxxxxxxxxxxxxxxxxx

# Admin API version
SHOPIFY_API_VERSION=2025-01

# Max number of products a creator can pick (keep in sync with the theme setting)
MAX_ITEMS=5

PORT=3000
