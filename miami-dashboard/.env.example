# Google Drive auto-load (optional).
# Copy this file to ".env" and fill in the two required values, then rebuild.
# When these are blank, the "Load latest from Google Drive" button is hidden and
# the dashboard works via manual upload only.

# OAuth 2.0 "Web application" Client ID from Google Cloud Console.
# Authorized JavaScript origins must include your deploy URL(s) + http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# The Drive folder that holds the weekly Miami reorder files.
# Folder ID = the part after /folders/ in the folder's URL.
VITE_DRIVE_FOLDER_ID=

# Optional filename filter so only matching files are considered (newest wins).
VITE_DRIVE_FILE_PREFIX=Reorder_Miami
