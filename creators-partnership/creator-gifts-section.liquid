{%- comment -%}
  ============================================================================
  CREATOR GIFTS — paste-in block (no app, no backend, no coupon)
  ONE free product per creator. Mobile-first tiles. Native cart -> checkout.
  Replace agreement_url with your Google Form responder link if it changes.
  ============================================================================
{%- endcomment -%}

{%- assign gift_collection = collections['creator-gifts'] -%}
{%- assign agreement_url = 'https://docs.google.com/forms/d/e/1FAIpQLSfRW-3NKnnzOcFAwP35nQCw08C0Fs3_qOi1o6Y4r7ej54ImeA/viewform' -%}

<style>
  .cg { --cg-accent:#f5631e; --cg-accent-2:#ff8a3d; max-width: 1000px; margin: 0 auto; padding: 1.25rem; }
  .cg__head { text-align: center; margin-bottom: 1.25rem; }
  .cg__head h1 { font-size: 1.9rem; font-weight: 800; margin: 0 0 .4rem; letter-spacing: -.01em; }
  .cg__head p { margin: 0; opacity: .8; }
  .cg__hint { font-size: .85rem; opacity: .65; }
  .cg__step { font-weight: 800; font-size: 1.05rem; margin: 1.6rem 0 .6rem; display: flex; align-items: center; gap: .5rem; }
  .cg__step::before { content: attr(data-n); display: inline-flex; align-items: center; justify-content: center; width: 1.5rem; height: 1.5rem; border-radius: 50%; background: var(--cg-accent); color: #fff; font-size: .8rem; }

  /* ---- product tiles (mobile-first: 2 across, image-dominant) ---- */
  .cg__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: .6rem; }
  @media (min-width: 600px) { .cg__grid { grid-template-columns: repeat(3, 1fr); gap: .9rem; } }
  @media (min-width: 900px) { .cg__grid { grid-template-columns: repeat(4, 1fr); } }

  .cg-tile { position: relative; border-radius: 16px; overflow: hidden; background: #fff; border: 2px solid transparent; box-shadow: 0 1px 5px rgba(0,0,0,.09); cursor: pointer; transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease; -webkit-tap-highlight-color: transparent; }
  .cg-tile:active { transform: scale(.98); }
  .cg-tile.is-on { border-color: var(--cg-accent); box-shadow: 0 6px 20px rgba(245,99,30,.32); }
  .cg-tile__media { position: relative; aspect-ratio: 1 / 1; background: #f3f3f3; }
  .cg-tile__media img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cg-tile.is-on .cg-tile__media::after { content: ""; position: absolute; inset: 0; background: rgba(245,99,30,.12); }
  .cg-tile__badge { position: absolute; top: .5rem; left: .5rem; background: var(--cg-accent); color: #fff; font-size: .65rem; font-weight: 800; letter-spacing: .04em; padding: .2rem .5rem; border-radius: 999px; }
  .cg-tile__check { position: absolute; top: .5rem; right: .5rem; width: 1.6rem; height: 1.6rem; border-radius: 50%; background: var(--cg-accent); color: #fff; display: none; align-items: center; justify-content: center; font-size: .95rem; font-weight: 800; box-shadow: 0 2px 6px rgba(0,0,0,.25); }
  .cg-tile.is-on .cg-tile__check { display: flex; }
  .cg-tile__body { padding: .5rem .6rem .65rem; }
  .cg-tile__title { font-size: .78rem; font-weight: 600; line-height: 1.25; display: block; }
  .cg-tile select { margin-top: .4rem; width: 100%; font-size: .78rem; padding: .3rem; border: 1px solid #ccc; border-radius: 6px; }
  .cg__sel { text-align: center; font-size: .9rem; margin-top: .8rem; }
  .cg__sel strong { color: var(--cg-accent); }

  /* ---- form ---- */
  .cg-form { margin-top: .4rem; display: grid; gap: .6rem; max-width: 520px; }
  .cg-field { display: grid; gap: .25rem; }
  .cg-field input { padding: .7rem; border: 1px solid #ccc; border-radius: 10px; width: 100%; font-size: 16px; }
  .cg-field input.is-bad { border-color: #c00; }
  .cg-field input.is-good { border-color: #1a7f37; }
  .cg-field__msg { font-size: .75rem; color: #c00; display: none; }
  .cg-field.is-bad .cg-field__msg { display: block; }

  .cg-agree { margin-top: 1.1rem; display: grid; gap: .6rem; max-width: 520px; }
  .cg-agree__open { display: inline-flex; align-items: center; gap: .3rem; padding: .6rem 1rem; border: 2px solid var(--cg-accent); border-radius: 10px; text-decoration: none; color: var(--cg-accent); font-weight: 700; width: max-content; }
  .cg-agree__check { display: flex; gap: .5rem; align-items: flex-start; font-size: .9rem; }
  .cg-agree__check input { margin-top: .2rem; width: 1.1rem; height: 1.1rem; }

  .cg__footer { margin-top: 1.6rem; display: grid; gap: .55rem; max-width: 520px; }
  .cg__todo { font-size: .8rem; opacity: .7; }
  .cg__cta { width: 100%; padding: 1.05rem; border: none; border-radius: 14px; background: linear-gradient(135deg, var(--cg-accent), var(--cg-accent-2)); color: #fff; font-size: 1.15rem; font-weight: 800; cursor: pointer; box-shadow: 0 8px 22px rgba(245,99,30,.38); transition: transform .12s ease, opacity .12s ease; }
  .cg__cta:active { transform: translateY(1px); }
  .cg__cta:disabled { background: #cfcfcf; box-shadow: none; cursor: not-allowed; }
  .cg-error { color: #c00; font-size: .85rem; }
</style>

<div class="cg" id="cg-app">
  <div class="cg__head">
    <h1>Get your free product 🎁</h1>
    <p>Pick <strong>one</strong> item on us — we'll ship it your way.</p>
  </div>

  {%- if gift_collection == blank or gift_collection.products_count == 0 -%}
    <p>No gift products are available right now. (Add products to the “Creator Gifts” collection.)</p>
  {%- else -%}

    <p class="cg__step" data-n="1">Choose your product</p>
    <div class="cg__grid">
      {%- for product in gift_collection.products -%}
        <div class="cg-tile" data-tile data-title="{{ product.title | remove: '[Creator Gift]' | strip | escape }}">
          <div class="cg-tile__media">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | image_url: width: 600 }}" alt="{{ product.title | escape }}" loading="lazy" width="600">
            {%- endif -%}
            <span class="cg-tile__badge">FREE</span>
            <span class="cg-tile__check" aria-hidden="true">✓</span>
          </div>
          <div class="cg-tile__body">
            <span class="cg-tile__title">{{ product.title | remove: '[Creator Gift]' | strip }}</span>
            {%- if product.variants.size > 1 -%}
              <select data-variant>
                {%- for v in product.variants -%}
                  <option value="{{ v.id }}" {% unless v.available %}disabled{% endunless %}>
                    {{ v.title }}{% unless v.available %} — Sold out{% endunless %}
                  </option>
                {%- endfor -%}
              </select>
            {%- else -%}
              <input type="hidden" data-variant value="{{ product.variants.first.id }}">
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
    <p class="cg__sel">Selected: <strong data-sel>none yet</strong></p>

    <p class="cg__step" data-n="2">Where can we see your content?</p>
    <p class="cg__hint">Add at least one — Instagram, TikTok, or YouTube.</p>
    <div class="cg-form">
      <div class="cg-field">
        <input type="text" data-social="Instagram" placeholder="Instagram handle (e.g. @yourname)">
        <span class="cg-field__msg">That doesn't look like a valid Instagram handle.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="TikTok" placeholder="TikTok handle (e.g. @yourname)">
        <span class="cg-field__msg">That doesn't look like a valid TikTok handle.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="YouTube" placeholder="YouTube channel (@handle or link)">
        <span class="cg-field__msg">That doesn't look like a valid YouTube channel.</span>
      </div>
      <div class="cg-field">
        <input type="text" data-social="Other" placeholder="Other (optional)">
      </div>
    </div>

    <p class="cg__step" data-n="3">Sign the agreement</p>
    <div class="cg-agree">
      <a class="cg-agree__open" href="{{ agreement_url }}" target="_blank" rel="noopener">Read &amp; sign the agreement ↗</a>
      <label class="cg-agree__check">
        <input type="checkbox" data-agree>
        <span>I have read, signed, and agree to the influencer agreement — I'll receive this item free in exchange for a social media post/video.</span>
      </label>
    </div>

    <div class="cg__footer">
      <p class="cg-error" data-error hidden></p>
      <p class="cg__todo" data-todo></p>
      <button type="button" class="cg__cta" data-checkout disabled>Create &amp; ship my partner box 🎁</button>
    </div>
  {%- endif -%}
</div>

<script>
(function () {
  var app = document.getElementById('cg-app');
  if (!app) return;

  var selEl = null, selVariant = null, selTitle = null;
  var selOut = app.querySelector('[data-sel]');
  var checkoutBtn = app.querySelector('[data-checkout]');
  var agreeEl = app.querySelector('[data-agree]');
  var errorEl = app.querySelector('[data-error]');
  var todoEl = app.querySelector('[data-todo]');

  // ---------- single product selection ----------
  app.querySelectorAll('[data-tile]').forEach(function (tile) {
    var variant = tile.querySelector('[data-variant]');
    if (!variant) return;

    tile.addEventListener('click', function (e) {
      if (e.target.closest('[data-variant]')) return; // let the dropdown work
      if (selEl === tile) {            // tap again to deselect
        tile.classList.remove('is-on');
        selEl = null; selVariant = null; selTitle = null;
      } else {
        if (selEl) selEl.classList.remove('is-on');
        selEl = tile; tile.classList.add('is-on');
        selVariant = variant.value;
        selTitle = tile.getAttribute('data-title');
      }
      refresh();
    });

    if (variant.tagName === 'SELECT') {
      variant.addEventListener('click', function (e) { e.stopPropagation(); });
      variant.addEventListener('change', function () { if (selEl === tile) selVariant = variant.value; });
    }
  });

  // ---------- social handle validation (lenient, must contain a letter) ----------
  function clean(v) { return v.trim().replace(/^@+/, '').replace(/\/+$/, ''); }
  function isHandle(v, max) { return new RegExp('^[a-zA-Z0-9._]{2,' + max + '}$').test(v) && /[a-zA-Z]/.test(v); }
  var validators = {
    Instagram: function (v) { return /instagram\.com\/[a-zA-Z0-9._]{2,}/i.test(v) || isHandle(clean(v), 30); },
    TikTok:    function (v) { return /tiktok\.com\/@?[a-zA-Z0-9._]{2,}/i.test(v) || isHandle(clean(v), 24); },
    YouTube:   function (v) { return /(youtube\.com|youtu\.be)\/.+/i.test(v) || (isHandle(clean(v), 30) && clean(v).length >= 3); }
  };

  var socialInputs = Array.prototype.slice.call(app.querySelectorAll('[data-social]'));
  socialInputs.forEach(function (input) {
    input.addEventListener('input', function () {
      var type = input.getAttribute('data-social');
      var field = input.closest('.cg-field');
      var val = input.value.trim();
      var check = validators[type];
      if (!val || !check) {
        input.classList.remove('is-bad', 'is-good');
        if (field) field.classList.remove('is-bad');
      } else if (check(val)) {
        input.classList.add('is-good'); input.classList.remove('is-bad');
        if (field) field.classList.remove('is-bad');
      } else {
        input.classList.add('is-bad'); input.classList.remove('is-good');
        if (field) field.classList.add('is-bad');
      }
      refresh();
    });
  });

  function hasValidSocial() {
    return ['Instagram', 'TikTok', 'YouTube'].some(function (type) {
      var input = app.querySelector('[data-social="' + type + '"]');
      var val = input ? input.value.trim() : '';
      return val && validators[type](val);
    });
  }

  agreeEl.addEventListener('change', refresh);

  function refresh() {
    var needs = [];
    if (!selVariant) needs.push('pick 1 product');
    if (!hasValidSocial()) needs.push('add a valid Instagram, TikTok, or YouTube');
    if (!agreeEl.checked) needs.push('check the agreement box');

    selOut.textContent = selTitle || 'none yet';
    checkoutBtn.disabled = needs.length > 0;
    todoEl.textContent = needs.length ? 'To continue: ' + needs.join(', ') + '.' : '';
  }
  refresh();

  // ---------- checkout ----------
  checkoutBtn.addEventListener('click', function () {
    errorEl.hidden = true;
    if (checkoutBtn.disabled || !selVariant) return;

    checkoutBtn.disabled = true;
    checkoutBtn.textContent = 'Preparing…';

    var attributes = { 'Creator gift': 'Yes', 'Influencer agreement': 'Accepted' };
    socialInputs.forEach(function (input) {
      if (input.value.trim()) attributes[input.getAttribute('data-social')] = input.value.trim();
    });

    var items = [{ id: Number(selVariant), quantity: 1 }];

    fetch('/cart/clear.js', { method: 'POST', headers: { 'Content-Type': 'application/json' } })
      .then(function () {
        return fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: items })
        });
      })
      .then(function (r) { if (!r.ok) throw new Error('Could not add the item to the cart.'); return r.json(); })
      .then(function () {
        return fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attributes: attributes })
        });
      })
      .then(function () { window.location.href = '/checkout'; })
      .catch(function (err) {
        showError(err.message || 'Something went wrong. Please try again.');
        checkoutBtn.disabled = false;
        checkoutBtn.textContent = 'Create & ship my partner box 🎁';
      });
  });

  function showError(msg) { errorEl.textContent = msg; errorEl.hidden = false; }
})();
</script>
